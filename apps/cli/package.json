{
  "name": "@thisisayande/contextcarry",
  "version": "0.2.7",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ctx": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "test": "vitest",
    "postinstall": "node -e \"console.log('\\n  Context Carry installed!\\n  Run: ctx init\\n');\""
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "contextcarry-core": "workspace:*",
    "contextcarry-types": "workspace:*",
    "ora": "^9.2.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
