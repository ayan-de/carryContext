{
  "name": "@thisisayande/contextcarry-mcp",
  "version": "0.1.0",
  "description": "MCP server for Context Carry — save and restore AI session context across editors",
  "type": "module",
  "license": "MIT",
  "author": "Ayan De <ayan-de>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayan-de/carryContext",
    "directory": "apps/mcp"
  },
  "keywords": [
    "mcp",
    "context",
    "ai",
    "session",
    "cursor",
    "windsurf",
    "cline",
    "claude",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "contextcarry-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "test": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "contextcarry-core": "workspace:*",
    "contextcarry-types": "workspace:*",
    "fastmcp": "^3.34.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
